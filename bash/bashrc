## Bazel Project support
if [ $(which bazel) ]; then
    function REPO_ROOT {
        while [ "$PWD" != '/' ]; do
            if [ -f "$PWD/WORKSPACE" ]; then
                echo "$PWD"
                return
            fi
            cd ..
        done
        echo "//[DOES_NOT_EXIST]"
    }

    alias repo_root='cd "$(REPO_ROOT)"'
    alias cdroot='repo_root'
    alias cdg3='repo_root'
fi

