# PS_Face — extended with zsh-equivalent exit codes
PS_FACE='\[\e[1;33m\]$(CODE=$?; if [ $CODE -eq 0 ]; then echo -e "\[\e[1;44m\]:-)"; elif [ $CODE -eq 146 ]; then echo -e "\[\e[1;44m\].zZ"; elif [ $CODE -eq 137 ]; then echo -e "\[\e[1;44m\]X_X"; else echo -e "\[\e[1;41m\]:-("; fi)'
RED='\[\e[1;31m\]'
WHITE='\[\e[1;37m\]'
YELLOW='\[\e[1;33m\]'
NORM='\[\e[0m\]'

# RPS1: date/time right prompt
RPS1='\[\e[1;30m\]\[\e[1;46m\][$(date +%a\ %m/%d\ %r)]\[\e[0m\]'

# Functions
function cleanall {
    find . -type f -regex '.*[#~]$' -or -regex '.*/\.[^/]*\.swp$' -or -name '~$*' -or -name '.DS_Store' -or -name '._fseventsd' -or -name '._*' | while read FN; do
        rm -f "$FN" && echo "Deleted: $FN"
    done
}

function tbgs {
    if [ $# -eq 0 ]; then
        echo "Usage: tbgs <str to find>"
        return 1
    fi
    grep --color=auto --exclude='*[~#]' -nire "$@" . 2> /dev/null
    return $?
}

function force_kill {
    if [ $# -ne 1 ]; then
        echo "You need to provide a target."
        return 1
    fi
    ps ax | grep -i "$1" | grep -v grep | while read A B; do echo $A; done | sudo xargs kill -9
}

## Platform Detection
# Homebrew
_HOMEBREW_ROOT="/usr/local"
if [[ $_SYSTEM == 'Darwin' ]]; then
    export BASH_SILENCE_DEPRECATION_WARNING=1
    export CLICOLOR=1
    export LSCOLORS=ExFxBxDxCxegedabagacad

    _CPU="$(sysctl -n machdep.cpu.brand_string)"
    _CPU="${_CPU:0:5}"

    if [[ "$_CPU" == "Apple" ]]; then
        _HOMEBREW_ROOT="/opt/homebrew"
    fi
    [ -f "$_HOMEBREW_ROOT/bin/brew" ] && eval "$($_HOMEBREW_ROOT/bin/brew shellenv)"

    alias ls='ls -GFh'
elif [[ $_SYSTEM == 'Linux' ]]; then
    _HOMEBREW_ROOT="/usr/local"
    alias ls='ls --color=auto -Fh'
    alias pbcopy='xclip -selection clipboard'
    alias pbpaste='xclip -selection clipboard -o'
fi

