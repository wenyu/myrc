## Prompt Setup
# Rosetta2 indicator: show on Apple Silicon Mac when running under Rosetta (x86_64 process on arm64 hardware)
if [[ $_SYSTEM == 'Darwin' && "$_CPU" == "Apple" && "$_ARCH" == "x86_64" ]]; then
    _ROSETTA='$(echo -e "\[\e[1;31m\]Rosetta2${NORM} ")'
else
    _ROSETTA='$(echo "")'
fi

# Full PS1: smiley on first line, user@host: git-branch [path] on second, Rosetta on third
# Uses $(id -u) to show '#' for root (uid 0) and '>' for regular users (bash-native, replaces zsh's %(!.#.>))
PS1="\n$PS_FACE$NORM \u@\h:${YELLOW}${GIT_PS1}${NORM}[\w]\n${_ROSETTA}${RED}$(if [ "$(id -u)" -eq 0 ]; then echo -e '#'; else echo -e '>'; fi)${NORM} "
